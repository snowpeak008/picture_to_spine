  "required": ["schemaVersion", "status", "diagnosticCode", "executablePath", "message"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "status": { "enum": ["STARTED", "NOT_BUILT", "FAILED"] },
