{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"F2S-SCHEMA-PROJECT-001","type":"object","additionalProperties":false,
  "required":["schemaVersion","identity","revision","timeBase","workflowStage","sourceArtifacts","activeMaster","activeLayerSet","layerProvenance","activeRig","motionContent","animationSet","approvalLog","reviewLog","exportRecords"],
  "properties":{
    "schemaVersion":{"const":"1.4.0"},
    "identity":{"type":"object","additionalProperties":false,"required":["projectId","displayName"],"properties":{"projectId":{"type":"string","format":"uuid"},"displayName":{"type":"string","minLength":1,"maxLength":120}}},
    "revision":{"type":"integer","minimum":0},"timeBase":{"$ref":"common.schema.json#/$defs/TimeBase"},"workflowStage":{"enum":["draft","master","layers","rig","animation","review","export"]},
    "sourceArtifacts":{"type":"array","items":{"$ref":"#/$defs/SourceArtifact"}},"activeMaster":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Master"}]},"activeLayerSet":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/LayerSet"}]},"layerProvenance":{"type":"array","items":{"$ref":"#/$defs/PixelProvenance"}},"activeRig":{"oneOf":[{"type":"null"},{"$ref":"rig-candidate.schema.json"}]},"motionContent":{"oneOf":[{"type":"null"},{"$ref":"motion-content.schema.json"}]},"animationSet":{"oneOf":[{"type":"null"},{"$ref":"animation-set.schema.json"}]},"approvalLog":{"type":"array","items":{"$ref":"#/$defs/Approval"}},"reviewLog":{"type":"array","items":{"$ref":"#/$defs/Review"}},"exportRecords":{"type":"array","items":{"$ref":"#/$defs/ExportRecord"}}
  },
  "$defs":{
    "SourceArtifact":{"type":"object","additionalProperties":false,"required":["artifactId","sha256","mediaType","width","height","byteLength","bitDepth","provenance","approvalState"],"properties":{"artifactId":{"$ref":"common.schema.json#/$defs/StableId"},"sha256":{"$ref":"common.schema.json#/$defs/Sha256"},"mediaType":{"enum":["image/png","image/jpeg","image/webp"]},"width":{"type":"integer","minimum":1},"height":{"type":"integer","minimum":1},"byteLength":{"type":"integer","minimum":1},"bitDepth":{"const":8},"provenance":{"type":"string"},"approvalState":{"enum":["UNAPPROVED","APPROVED","INVALIDATED"]}}},
    "Weapon":{"type":"object","additionalProperties":false,"required":["weaponType","gripMode","weaponHand","socketSemantic","sizeClass","silhouetteConstraints"],"properties":{"weaponType":{"type":"string","minLength":1},"gripMode":{"enum":["one-hand","two-hand","flexible"]},"weaponHand":{"enum":["near-hand","far-hand","both-hands"]},"socketSemantic":{"type":"string","minLength":1},"sizeClass":{"enum":["small","medium","large"]},"silhouetteConstraints":{"type":"string","minLength":1}}},
    "Style":{"type":"object","additionalProperties":false,"required":["revision","viewpoint","renderingStyle","outline","paletteNotes","identityNotes","primaryWeapon"],"properties":{"revision":{"type":"integer","minimum":0},"viewpoint":{"const":"side-view"},"renderingStyle":{"type":"string"},"outline":{"type":"string"},"paletteNotes":{"type":"string"},"identityNotes":{"type":"string","minLength":1},"primaryWeapon":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Weapon"}]}}},
    "Master":{"type":"object","additionalProperties":false,"required":["masterId","sourceArtifactId","candidateRevision","sourceSha256","styleSpec","approvalState","supersedes"],"properties":{"masterId":{"$ref":"common.schema.json#/$defs/StableId"},"sourceArtifactId":{"$ref":"common.schema.json#/$defs/StableId"},"candidateRevision":{"type":"integer","minimum":0},"sourceSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"styleSpec":{"$ref":"#/$defs/Style"},"approvalState":{"enum":["PENDING","APPROVED","REJECTED","INVALIDATED"]},"supersedes":{"type":["string","null"]}}},
    "Layer":{"type":"object","additionalProperties":false,"required":["layerId","name","role","attachmentSha256","maskSha256","visible","approved"],"properties":{"layerId":{"$ref":"common.schema.json#/$defs/StableId"},"name":{"type":"string","minLength":1,"maxLength":120},"role":{"enum":["hair-back","body","head","hair-front","upper-arm-back","forearm-back","upper-arm-front","forearm-front","hand-back","hand-front","thigh-back","shin-back","foot-back","thigh-front","shin-front","foot-front","weapon","accessory"]},"attachmentSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"maskSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"visible":{"type":"boolean"},"approved":{"type":"boolean"}}},
    "LayerSet":{"type":"object","additionalProperties":false,"required":["layerSetId","masterId","revision","layers","approvalState"],"properties":{"layerSetId":{"$ref":"common.schema.json#/$defs/StableId"},"masterId":{"$ref":"common.schema.json#/$defs/StableId"},"revision":{"type":"integer","minimum":0},"layers":{"type":"array","minItems":1,"maxItems":256,"items":{"$ref":"#/$defs/Layer"}},"approvalState":{"enum":["PENDING","APPROVED","INVALIDATED"]}}},
    "PixelProvenance":{"type":"object","additionalProperties":false,"required":["artifactSha256","origin","sourceSha256","promptPackId","receiptRef","acceptedBy","acceptanceAttestationSha256"],"properties":{"artifactSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"origin":{"enum":["SOURCE","MANUAL","LOCAL_AI","PRIVATE_REMOTE_AI"]},"sourceSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"promptPackId":{"type":["string","null"]},"receiptRef":{"type":["string","null"]},"acceptedBy":{"type":["string","null"]},"acceptanceAttestationSha256":{"oneOf":[{"type":"null"},{"$ref":"common.schema.json#/$defs/Sha256"}]}}},
    "Approval":{"type":"object","additionalProperties":false,"required":["approvalId","gateId","targetId","targetRevision","targetSha256","actorId","approvedAtUtc","invalidated"],"properties":{"approvalId":{"type":"string"},"gateId":{"type":"string"},"targetId":{"type":"string"},"targetRevision":{"type":"integer","minimum":0},"targetSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"actorId":{"type":"string"},"approvedAtUtc":{"type":"string"},"invalidated":{"type":"boolean"}}},
    "Review":{"type":"object","additionalProperties":false,"required":["reviewId","gateId","targetId","targetRevision","targetSha256","actorId","outcome","reason","reviewedAtUtc"],"properties":{"reviewId":{"type":"string"},"gateId":{"type":"string"},"targetId":{"type":"string"},"targetRevision":{"type":"integer","minimum":0},"targetSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"actorId":{"type":"string"},"outcome":{"const":"REJECTED"},"reason":{"type":"string","minLength":1,"maxLength":1000},"reviewedAtUtc":{"type":"string"}}},
    "ExportRecord":{"type":"object","additionalProperties":false,"required":["exportId","snapshotSha256","sourceProjectRevision","status","checksums","createdAtUtc","externalStatus"],"properties":{"exportId":{"type":"string","minLength":1,"maxLength":80,"pattern":"^[A-Za-z0-9_-]+$"},"snapshotSha256":{"$ref":"common.schema.json#/$defs/Sha256"},"sourceProjectRevision":{"type":"integer","minimum":0},"status":{"const":"EXPORTED_UNVERIFIED"},"checksums":{"type":"object","minProperties":1,"propertyNames":{"type":"string","minLength":1},"additionalProperties":{"$ref":"common.schema.json#/$defs/Sha256"}},"createdAtUtc":{"type":"string","format":"date-time"},"externalStatus":{"const":"EXPORTED_UNVERIFIED"}}}
  }
}
