{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "F2S-SCHEMA-EVIDENCE-001", "title": "EvidenceEnvelope", "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "evidenceId", "taskId", "status", "command", "exitCode", "startedAtUtc", "endedAtUtc", "runner", "toolVersions", "inputHashes", "outputHashes", "logRefs", "reportRefs", "capabilityState", "externalBlockers", "previousEvidenceRef", "notRunReason", "payload"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" }, "evidenceId": { "type": "string" }, "taskId": { "type": "string", "pattern": "^F2S-DEV-M[0-9]{2}-[0-9]{3}$" },
    "status": { "enum": ["PASS", "FAIL", "NOT_RUN"] }, "command": { "type": "string" }, "exitCode": { "type": ["integer", "null"] }, "startedAtUtc": { "type": "string", "format": "date-time" }, "endedAtUtc": { "type": "string", "format": "date-time" },
    "runner": { "type": "object" }, "toolVersions": { "type": "object" }, "inputHashes": { "type": "object", "additionalProperties": { "$ref": "common.schema.json#/$defs/Sha256" } }, "outputHashes": { "type": "object", "additionalProperties": { "$ref": "common.schema.json#/$defs/Sha256" } },
    "logRefs": { "type": "array", "items": { "type": "string" } }, "reportRefs": { "type": "array", "items": { "type": "string" } }, "capabilityState": { "enum": ["VERIFIED", "UNVERIFIED", "FAILED", "EXTERNAL"] }, "externalBlockers": { "type": "array", "items": { "type": "string" } },
    "previousEvidenceRef": { "type": ["string", "null"] }, "notRunReason": { "type": ["string", "null"] }, "payload": { "type": "object" }
  },
  "allOf": [
    { "if": { "properties": { "status": { "const": "NOT_RUN" } } }, "then": { "properties": { "notRunReason": { "type": "string", "minLength": 1 } } } },
    { "if": { "properties": { "capabilityState": { "const": "EXTERNAL" } } }, "then": { "properties": { "externalBlockers": { "minItems": 1 } } } }
  ]
}
